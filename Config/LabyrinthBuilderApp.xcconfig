//
//  LabyrinthBuilderApp.xcconfig
//  Labyrinth Builder
//
//  Shared settings for the macOS app bundle target.
//

#include "LabyrinthBuilderShared.xcconfig"

SFML_HEADER_PREFIX = /opt/homebrew
SFML_LIBRARY_DIR = $(PROJECT_DIR)/ThirdParty/SFML/lib

SYSTEM_HEADER_SEARCH_PATHS = $(inherited) $(SFML_HEADER_PREFIX)/include
LIBRARY_SEARCH_PATHS = $(inherited) $(SFML_LIBRARY_DIR)

// This is the correct app-bundle runpath for dylibs embedded into:
// Labyrinth Builder App.app/Contents/Frameworks
LD_RUNPATH_SEARCH_PATHS = $(inherited) @executable_path/../Frameworks
